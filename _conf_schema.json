{
  "min_length": {
    "description": "单段最小字数",
    "type": "int",
    "default": 20,
    "hint": "触发断句的最小字数限制。"
  },
  "max_length": {
    "description": "常规则最大字数",
    "type": "int",
    "default": 50,
    "hint": "单条消息的常规则最大长度。"
  },
  "allow_exceed_max": {
    "description": "允许超出最大字数寻找断点",
    "type": "bool",
    "default": true,
    "hint": "若开启：在 [最小, 最大] 范围内没找到断点时，会继续往后找。\n若关闭：直接在最大字数处强制截断。"
  },
  "hard_max_limit": {
    "description": "绝对硬性截断字数",
    "type": "int",
    "default": 100,
    "hint": "防止无限的绝对上限。"
  },
  "merge_short_tail": {
    "description": "合并过短的尾部残余",
    "type": "bool",
    "default": true,
    "hint": "断句到最后如果只剩几个字，会将其与上一段合并。"
  },
  "short_tail_threshold": {
    "description": "短尾合并字数阈值",
    "type": "int",
    "default": 8,
    "hint": "最后一段剩余字数少于此值时，将触发短尾合并。"
  },
  "split_symbols": {
    "description": "断句符号/关键词列表",
    "type": "list",
    "default": [
      "\n\n",
      "\n",
      "。",
      "！",
      "？"
    ],
    "hint": "程序会优先搜索靠前的符号进行切割。"
  },
  "keep_symbol": {
    "description": "分段是否保留断点符号",
    "type": "bool",
    "default": true,
    "hint": "开启则断句后保留该符号；关闭则断句后直接丢弃。"
  },
  "exclude_keywords": {
    "description": "无需分段的关键词列表",
    "type": "list",
    "default": [
      "模型列表",
      "帮助",
      "help",
      "命令列表",
      "菜单",
      "功能列表"
    ],
    "hint": "包含以下关键词时，将跳过整段处理。"
  },
  "enable_string_replace": {
    "description": "启用字符串替换",
    "type": "bool",
    "default": true,
    "hint": "开启后将执行 string_replacements 列表中的替换规则。"
  },
  "enable_markdown_replace": {
    "description": "启用 Markdown 移除",
    "type": "bool",
    "default": true,
    "hint": "开启后将执行 markdown_replacements 列表中的 Markdown 格式移除规则。"
  },
  "string_replacements": {
    "description": "字符串替换规则列表",
    "type": "list",
    "default": [
      "😁=>🤪",
      "😂=>🤭"
    ],
    "hint": "格式: 原字符=>替换后字符"
  },
  "markdown_replacements": {
    "description": "Markdown 格式移除规则列表",
    "type": "list",
    "default": [
      {
        "pattern": "```(?:[a-zA-Z0-9+\\-]*\\s+)?([\\s\\S]*?)```",
        "replacement": "$1",
        "is_regex": true
      },
      {
        "pattern": "`([^`]+)`",
        "replacement": "$1",
        "is_regex": true
      },
      {
        "pattern": "\\*\\*([^*]+)\\*\\*",
        "replacement": "$1",
        "is_regex": true
      },
      {
        "pattern": "__([^_]+)__",
        "replacement": "$1",
        "is_regex": true
      },
      {
        "pattern": "\\*([^*]+)\\*",
        "replacement": "$1",
        "is_regex": true
      },
      {
        "pattern": "_([^_]+)_",
        "replacement": "$1",
        "is_regex": true
      },
      {
        "pattern": "^#{1,6}\\s+",
        "replacement": "",
        "is_regex": true
      },
      {
        "pattern": "^>\\s*",
        "replacement": "",
        "is_regex": true
      },
      {
        "pattern": "!\\[([^]]*)\\]\\([^)]+\\)",
        "replacement": "$1",
        "is_regex": true
      },
      {
        "pattern": "\\[([^]]+)\\]\\([^)]+\\)",
        "replacement": "$1",
        "is_regex": true
      },
      {
        "pattern": "^\\s*[-*+]\\s+",
        "replacement": "",
        "is_regex": true
      },
      {
        "pattern": "^\\s*\\d+\\.\\s+",
        "replacement": "",
        "is_regex": true
      },
      {
        "pattern": "~~([^~]+)~~",
        "replacement": "$1",
        "is_regex": true
      }
    ],
    "hint": "正则表达式格式的 Markdown 格式移除规则"
  }
}
